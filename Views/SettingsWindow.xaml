<Window x:Class="WhisperWriter.Views.SettingsWindow"
		xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		Title="Settings"
		Width="460" Height="420"
		WindowStyle="None"
		AllowsTransparency="True"
		Background="Transparent"
		WindowStartupLocation="CenterScreen"
		ResizeMode="NoResize">

	<Border Background="{StaticResource BgBrush}"
			CornerRadius="14"
			MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
		<Border.Effect>
			<DropShadowEffect Color="Black" BlurRadius="24" ShadowDepth="6" Opacity="0.55"/>
		</Border.Effect>

		<Grid Margin="20">
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/>
				<!-- title -->
				<RowDefinition Height="16"/>
				<RowDefinition Height="Auto"/>
				<!-- model path -->
				<RowDefinition Height="12"/>
				<RowDefinition Height="Auto"/>
				<!-- language -->
				<RowDefinition Height="12"/>
				<RowDefinition Height="Auto"/>
				<!-- prompt -->
				<RowDefinition Height="12"/>
				<RowDefinition Height="Auto"/>
				<!-- hotkey -->
				<RowDefinition Height="12"/>
				<RowDefinition Height="Auto"/>
				<!-- history size -->
				<RowDefinition Height="*"/>
				<RowDefinition Height="Auto"/>
				<!-- buttons -->
			</Grid.RowDefinitions>

			<!-- Title -->
			<Grid Grid.Row="0">
				<TextBlock Text="Settings"
						   Foreground="{StaticResource TextPrimaryBrush}"
						   FontSize="14" FontWeight="SemiBold" FontFamily="Segoe UI"/>
				<Button Style="{StaticResource IconButton}"
						Content="✕"
						HorizontalAlignment="Right"
						Click="BtnCancel_Click"/>
			</Grid>

			<!-- Model -->
			<StackPanel Grid.Row="2">
				<TextBlock Text="Model" Foreground="{StaticResource TextSecondaryBrush}"
						   FontSize="11" FontFamily="Segoe UI" Margin="0,0,0,4"/>
				<ComboBox x:Name="CmbModelPath"
						  Background="#33FFFFFF" Foreground="{StaticResource TextPrimaryBrush}"
						  BorderBrush="#44FFFFFF"
						  FontFamily="Segoe UI" FontSize="13" Padding="6,4">
					<ComboBoxItem Tag="models/ggml-large-v3-turbo.bin">
						<StackPanel>
							<TextBlock Text="large-v3-turbo  (best speed/accuracy tradeoff)"
									   FontWeight="SemiBold"/>
							<TextBlock Text="~3 GB VRAM · 1.6 GB disk · CUDA GPU recommended"
									   FontSize="11" Opacity="0.65"/>
						</StackPanel>
					</ComboBoxItem>
					<ComboBoxItem Tag="models/ggml-large-v3.bin">
						<StackPanel>
							<TextBlock Text="large-v3  (most accurate, latest)"
									   FontWeight="SemiBold"/>
							<TextBlock Text="~10 GB VRAM · 3 GB disk · CUDA GPU strongly recommended"
									   FontSize="11" Opacity="0.65"/>
						</StackPanel>
					</ComboBoxItem>
					<ComboBoxItem Tag="models/ggml-large-v2.bin">
						<StackPanel>
							<TextBlock Text="large-v2  (most accurate, recommended)"
									   FontWeight="SemiBold"/>
							<TextBlock Text="~10 GB VRAM · 3 GB disk · CUDA GPU strongly recommended"
									   FontSize="11" Opacity="0.65"/>
						</StackPanel>
					</ComboBoxItem>
					<ComboBoxItem Tag="models/ggml-large-v1.bin">
						<StackPanel>
							<TextBlock Text="large-v1  (accurate, older generation)"
									   FontWeight="SemiBold"/>
							<TextBlock Text="~10 GB VRAM · 3 GB disk · CUDA GPU strongly recommended"
									   FontSize="11" Opacity="0.65"/>
						</StackPanel>
					</ComboBoxItem>
					<ComboBoxItem Tag="models/ggml-medium.bin">
						<StackPanel>
							<TextBlock Text="medium  (good balance, multilingual)"
									   FontWeight="SemiBold"/>
							<TextBlock Text="~5 GB VRAM · 1.5 GB disk · runs on CPU"
									   FontSize="11" Opacity="0.65"/>
						</StackPanel>
					</ComboBoxItem>
					<ComboBoxItem Tag="models/ggml-medium.en.bin">
						<StackPanel>
							<TextBlock Text="medium.en  (good balance, English only)"
									   FontWeight="SemiBold"/>
							<TextBlock Text="~5 GB VRAM · 1.5 GB disk · runs on CPU"
									   FontSize="11" Opacity="0.65"/>
						</StackPanel>
					</ComboBoxItem>
					<ComboBoxItem Tag="models/ggml-small.bin">
						<StackPanel>
							<TextBlock Text="small  (fast, multilingual)"
									   FontWeight="SemiBold"/>
							<TextBlock Text="~2 GB VRAM · 488 MB disk · runs on CPU"
									   FontSize="11" Opacity="0.65"/>
						</StackPanel>
					</ComboBoxItem>
					<ComboBoxItem Tag="models/ggml-small.en.bin">
						<StackPanel>
							<TextBlock Text="small.en  (fast, English only)"
									   FontWeight="SemiBold"/>
							<TextBlock Text="~2 GB VRAM · 488 MB disk · runs on CPU"
									   FontSize="11" Opacity="0.65"/>
						</StackPanel>
					</ComboBoxItem>
					<ComboBoxItem Tag="models/ggml-base.bin">
						<StackPanel>
							<TextBlock Text="base  (very fast, multilingual)"
									   FontWeight="SemiBold"/>
							<TextBlock Text="~1 GB VRAM · 148 MB disk · runs on CPU"
									   FontSize="11" Opacity="0.65"/>
						</StackPanel>
					</ComboBoxItem>
					<ComboBoxItem Tag="models/ggml-base.en.bin">
						<StackPanel>
							<TextBlock Text="base.en  (very fast, English only)"
									   FontWeight="SemiBold"/>
							<TextBlock Text="~1 GB VRAM · 148 MB disk · runs on CPU"
									   FontSize="11" Opacity="0.65"/>
						</StackPanel>
					</ComboBoxItem>
					<ComboBoxItem Tag="models/ggml-tiny.bin">
						<StackPanel>
							<TextBlock Text="tiny  (fastest, multilingual, least accurate)"
									   FontWeight="SemiBold"/>
							<TextBlock Text="~390 MB VRAM · 78 MB disk · runs on CPU"
									   FontSize="11" Opacity="0.65"/>
						</StackPanel>
					</ComboBoxItem>
					<ComboBoxItem Tag="models/ggml-tiny.en.bin">
						<StackPanel>
							<TextBlock Text="tiny.en  (fastest, English only, least accurate)"
									   FontWeight="SemiBold"/>
							<TextBlock Text="~390 MB VRAM · 78 MB disk · runs on CPU"
									   FontSize="11" Opacity="0.65"/>
						</StackPanel>
					</ComboBoxItem>
				</ComboBox>
			</StackPanel>

			<!-- Language -->
			<StackPanel Grid.Row="4">
				<TextBlock Text="Language" Foreground="{StaticResource TextSecondaryBrush}"
						   FontSize="11" FontFamily="Segoe UI" Margin="0,0,0,4"/>
				<ComboBox x:Name="CmbLanguage"
						  Background="#33FFFFFF" Foreground="{StaticResource TextPrimaryBrush}"
						  BorderBrush="#44FFFFFF"
						  FontFamily="Segoe UI" FontSize="13" Padding="6,4">
					<ComboBoxItem Content="auto – Auto (detect)" Tag="auto"/>
					<ComboBoxItem Content="af – Afrikaans" Tag="af"/>
					<ComboBoxItem Content="ar – العربية" Tag="ar"/>
					<ComboBoxItem Content="hy – Հայերեն" Tag="hy"/>
					<ComboBoxItem Content="az – Azərbaycan" Tag="az"/>
					<ComboBoxItem Content="be – Беларуская" Tag="be"/>
					<ComboBoxItem Content="bs – Bosanski" Tag="bs"/>
					<ComboBoxItem Content="bg – Български" Tag="bg"/>
					<ComboBoxItem Content="ca – Català" Tag="ca"/>
					<ComboBoxItem Content="zh – 中文" Tag="zh"/>
					<ComboBoxItem Content="hr – Hrvatski" Tag="hr"/>
					<ComboBoxItem Content="cs – Čeština" Tag="cs"/>
					<ComboBoxItem Content="da – Dansk" Tag="da"/>
					<ComboBoxItem Content="nl – Nederlands" Tag="nl"/>
					<ComboBoxItem Content="en – English" Tag="en"/>
					<ComboBoxItem Content="et – Eesti" Tag="et"/>
					<ComboBoxItem Content="fi – Suomi" Tag="fi"/>
					<ComboBoxItem Content="fr – Français" Tag="fr"/>
					<ComboBoxItem Content="gl – Galego" Tag="gl"/>
					<ComboBoxItem Content="de – Deutsch" Tag="de"/>
					<ComboBoxItem Content="el – Ελληνικά" Tag="el"/>
					<ComboBoxItem Content="he – עברית" Tag="he"/>
					<ComboBoxItem Content="hi – हिन्दी" Tag="hi"/>
					<ComboBoxItem Content="hu – Magyar" Tag="hu"/>
					<ComboBoxItem Content="is – Íslenska" Tag="is"/>
					<ComboBoxItem Content="id – Bahasa Indonesia" Tag="id"/>
					<ComboBoxItem Content="it – Italiano" Tag="it"/>
					<ComboBoxItem Content="ja – 日本語" Tag="ja"/>
					<ComboBoxItem Content="kn – ಕನ್ನಡ" Tag="kn"/>
					<ComboBoxItem Content="kk – Қазақша" Tag="kk"/>
					<ComboBoxItem Content="ko – 한국어" Tag="ko"/>
					<ComboBoxItem Content="lv – Latviešu" Tag="lv"/>
					<ComboBoxItem Content="lt – Lietuvių" Tag="lt"/>
					<ComboBoxItem Content="mk – Македонски" Tag="mk"/>
					<ComboBoxItem Content="ms – Bahasa Melayu" Tag="ms"/>
					<ComboBoxItem Content="mi – Māori" Tag="mi"/>
					<ComboBoxItem Content="mr – मराठी" Tag="mr"/>
					<ComboBoxItem Content="ne – नेपाली" Tag="ne"/>
					<ComboBoxItem Content="no – Norsk" Tag="no"/>
					<ComboBoxItem Content="fa – فارسی" Tag="fa"/>
					<ComboBoxItem Content="pl – Polski" Tag="pl"/>
					<ComboBoxItem Content="pt – Português" Tag="pt"/>
					<ComboBoxItem Content="ro – Română" Tag="ro"/>
					<ComboBoxItem Content="ru – Русский" Tag="ru"/>
					<ComboBoxItem Content="sr – Српски" Tag="sr"/>
					<ComboBoxItem Content="sk – Slovenčina" Tag="sk"/>
					<ComboBoxItem Content="sl – Slovenščina" Tag="sl"/>
					<ComboBoxItem Content="es – Español" Tag="es"/>
					<ComboBoxItem Content="sw – Kiswahili" Tag="sw"/>
					<ComboBoxItem Content="sv – Svenska" Tag="sv"/>
					<ComboBoxItem Content="tl – Filipino" Tag="tl"/>
					<ComboBoxItem Content="ta – தமிழ்" Tag="ta"/>
					<ComboBoxItem Content="th – ภาษาไทย" Tag="th"/>
					<ComboBoxItem Content="tr – Türkçe" Tag="tr"/>
					<ComboBoxItem Content="uk – Українська" Tag="uk"/>
					<ComboBoxItem Content="ur – اردو" Tag="ur"/>
					<ComboBoxItem Content="vi – Tiếng Việt" Tag="vi"/>
					<ComboBoxItem Content="cy – Cymraeg" Tag="cy"/>
				</ComboBox>
			</StackPanel>

			<!-- Prompt -->
			<StackPanel Grid.Row="6">
				<TextBlock Text="Prompt (helps Whisper with domain vocabulary)"
						   Foreground="{StaticResource TextSecondaryBrush}"
						   FontSize="11" FontFamily="Segoe UI" Margin="0,0,0,4"/>
				<TextBox x:Name="TxtPrompt"
						 Background="#33FFFFFF" Foreground="{StaticResource TextPrimaryBrush}"
						 BorderBrush="#44FFFFFF" BorderThickness="1"
						 FontFamily="Segoe UI" FontSize="13"
						 Padding="8,5" Height="60"
						 TextWrapping="Wrap" AcceptsReturn="True"
						 CaretBrush="White"
						 VerticalScrollBarVisibility="Auto"/>
			</StackPanel>

			<!-- Hotkey display (read-only info for now) -->
			<StackPanel Grid.Row="8">
				<TextBlock Text="Push-to-talk hotkey"
						   Foreground="{StaticResource TextSecondaryBrush}"
						   FontSize="11" FontFamily="Segoe UI" Margin="0,0,0,4"/>
				<TextBlock Text="Left Ctrl + Left Win  (hold to record)"
						   Foreground="{StaticResource TextPrimaryBrush}"
						   FontSize="13" FontFamily="Segoe UI"/>
			</StackPanel>

			<!-- History size -->
			<StackPanel Grid.Row="10">
				<TextBlock Text="History size (number of transcriptions kept in memory, 1 - 2 147 483 647)"
				           Foreground="{StaticResource TextSecondaryBrush}"
				           FontSize="11" FontFamily="Segoe UI" Margin="0,0,0,4"
				           TextWrapping="Wrap"/>
				<TextBox x:Name="TxtHistorySize"
				         Background="#33FFFFFF" Foreground="{StaticResource TextPrimaryBrush}"
				         BorderBrush="#44FFFFFF" BorderThickness="1"
				         FontFamily="Segoe UI" FontSize="13"
				         Padding="8,5"
				         CaretBrush="White"
				         PreviewTextInput="TxtHistorySize_PreviewTextInput"/>
			</StackPanel>

			<!-- Action buttons -->
			<StackPanel Grid.Row="12" Orientation="Horizontal" HorizontalAlignment="Right">
				<Button Style="{StaticResource IconButton}"
						Content="Cancel"
						Margin="0,0,8,0"
						Click="BtnCancel_Click"/>
				<Button x:Name="BtnSave"
						Style="{StaticResource IconButton}"
						Content="Save"
						Background="{StaticResource AccentBrush}"
						Foreground="White"
						Click="BtnSave_Click"/>
			</StackPanel>
		</Grid>
	</Border>
</Window>
