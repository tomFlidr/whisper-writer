<Window x:Class="WhisperWriter.Views.AboutWindow"
		xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		Title="About WhisperWriter"
		Width="480" Height="360"
		WindowStyle="None"
		AllowsTransparency="True"
		Background="Transparent"
		WindowStartupLocation="CenterScreen"
		ResizeMode="NoResize">

	<Border x:Name="WidgetBorder"
		Background="{StaticResource BgBrush}"
		CornerRadius="10"
		Padding="0"
		Opacity="0.97"
		BorderBrush="#66FFFFFF"
		BorderThickness="1"
		MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">

		<Grid>
			<Grid.RowDefinitions>
				<RowDefinition Height="44"/>
				<RowDefinition Height="*"/>
				<RowDefinition Height="Auto"/>
			</Grid.RowDefinitions>

			<!-- Title bar -->
			<Grid Grid.Row="0" Margin="16,0">
				<TextBlock Text="About WhisperWriter"
						   Foreground="{StaticResource TextPrimaryBrush}"
						   FontSize="14" FontWeight="SemiBold"
						   FontFamily="Segoe UI"
						   VerticalAlignment="Center"/>
				<Button Style="{StaticResource IconButton}"
						Content="✕"
						HorizontalAlignment="Right"
						VerticalAlignment="Center"
						Click="BtnClose_Click"/>
			</Grid>

			<Rectangle Grid.Row="0" VerticalAlignment="Bottom" Height="1"
					   Fill="#22FFFFFF"/>

			<!-- Content -->
			<ScrollViewer Grid.Row="1" Margin="20,12,20,0"
						  VerticalScrollBarVisibility="Auto"
						  HorizontalScrollBarVisibility="Disabled">
				<TextBlock TextWrapping="Wrap"
						   Foreground="{StaticResource TextPrimaryBrush}"
						   FontFamily="Segoe UI" FontSize="13"
						   LineHeight="22"><Run FontSize="18" FontWeight="SemiBold" Text="WhisperWriter"/><LineBreak/><LineBreak/><Run Foreground="#99FFFFFF" Text="Lokální hlasový přepis textu pro Windows. Drž klávesovou zkratku, mluv, pusť – text se vloží přímo tam, kde byl kurzor."/><LineBreak/><LineBreak/><Run FontWeight="SemiBold" Text="Jak to funguje"/><LineBreak/><Run Foreground="#99FFFFFF" Text="Nahrávka je zpracována lokálně modelem OpenAI Whisper (whisper.cpp) přes knihovnu Whisper.net. GPU akcelerace přes CUDA je použita automaticky, pokud je dostupná. Žádná data neopustí tvůj počítač."/><LineBreak/><LineBreak/><Run FontWeight="SemiBold" Text="Funkce"/><LineBreak/><Run Foreground="#99FFFFFF" Text="• Push-to-talk zkratka (výchozí: Levý Ctrl + Levý Win)"/><LineBreak/><Run Foreground="#99FFFFFF" Text="• VU meter zobrazující úroveň hlasu při nahrávání"/><LineBreak/><Run Foreground="#99FFFFFF" Text="• ETA odpočet doby přepisu"/><LineBreak/><Run Foreground="#99FFFFFF" Text="• Historie posledních přepisů"/><LineBreak/><Run Foreground="#99FFFFFF" Text="• Konfigurovatelný jazyk a prompt pro Whisper"/><LineBreak/><Run Foreground="#99FFFFFF" Text="• Plovoucí widget – přetahovatelný, vždy nahoře"/><LineBreak/><LineBreak/><Run FontWeight="SemiBold" Text="Modely"/><LineBreak/><Run Foreground="#99FFFFFF" Text="Podporuje ggml modely: tiny, base, small, medium, large-v2. Větší model = lepší přesnost, pomalejší přepis. large-v2 doporučen pro češtinu."/><LineBreak/><LineBreak/><Run Foreground="#55FFFFFF" FontSize="11" Text="Powered by OpenAI Whisper · whisper.cpp · Whisper.net · NAudio"/></TextBlock>
			</ScrollViewer>

			<!-- Footer -->
			<Border Grid.Row="2" BorderThickness="0,1,0,0" BorderBrush="#22FFFFFF" Padding="16,10">
				<Button Style="{StaticResource IconButton}"
						Content="Close"
						HorizontalAlignment="Right"
						Click="BtnClose_Click"/>
			</Border>
		</Grid>
	</Border>
</Window>
