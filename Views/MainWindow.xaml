<Window x:Class="WhisperWriter.Views.MainWindow"
		xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		Title="WhisperWriter"
		SizeToContent="WidthAndHeight"
		WindowStyle="None"
		AllowsTransparency="True"
		Background="Transparent"
		Topmost="True"
		ShowInTaskbar="False"
		ResizeMode="NoResize">

	<Window.Resources>
		<!-- Opacity: idle → 0.6, hover → 1.0 -->
		<Storyboard x:Key="FadeToHover">
			<DoubleAnimation Storyboard.TargetName="WidgetBorder"
							 Storyboard.TargetProperty="Opacity"
							 To="1.0" Duration="0:0:0.12"/>
		</Storyboard>
		<Storyboard x:Key="FadeToIdle">
			<DoubleAnimation Storyboard.TargetName="WidgetBorder"
							 Storyboard.TargetProperty="Opacity"
							 To="0.6" Duration="0:0:0.20"/>
		</Storyboard>
		<!-- Pulse animation for the recording dot -->
		<Storyboard x:Key="PulseAnim" RepeatBehavior="Forever">
			<DoubleAnimation Storyboard.TargetName="RecDot"
							 Storyboard.TargetProperty="Opacity"
							 From="1" To="0.2" Duration="0:0:0.6"
							 AutoReverse="True"/>
		</Storyboard>
		<!-- Fade-in on show -->
		<Storyboard x:Key="FadeIn">
			<DoubleAnimation Storyboard.TargetName="WidgetBorder"
							 Storyboard.TargetProperty="Opacity"
							 From="0" To="0.6" Duration="0:0:0.15"/>
		</Storyboard>
	</Window.Resources>

	<!-- Compact pill: minimal padding -->
	<Border x:Name="WidgetBorder"
			Background="{StaticResource BgBrush}"
			CornerRadius="10"
			Padding="10,5"
			Opacity="0.85"
			BorderBrush="#66FFFFFF"
			BorderThickness="1"
			MouseLeftButtonDown="handleMouseLeftButtonDown"
			MouseEnter="handleMouseEnter"
			MouseLeave="handleMouseLeave"
			Cursor="SizeAll">

		<StackPanel Orientation="Horizontal" VerticalAlignment="Center">

			<!-- Recording indicator dot -->
			<Ellipse x:Name="RecDot"
					 Width="10" Height="10"
					 Margin="0,0,8,0"
					 Fill="{StaticResource AccentBrush}"
					 VerticalAlignment="Center"/>

			<!-- Status text + ETA on one line -->
			<StackPanel VerticalAlignment="Center" Margin="0,0">
				
				<StackPanel Orientation="Horizontal">
					<TextBlock x:Name="StatusLabel"
							   Text="Ready"
							   Foreground="{StaticResource TextSecondaryBrush}"
							   FontSize="12"
							   FontFamily="Segoe UI"
							   VerticalAlignment="Center"/>
					<TextBlock x:Name="EtaLabel"
							   Foreground="{StaticResource AccentBrush}"
							   FontSize="12"
							   FontFamily="Segoe UI"
							   Margin="6,0,0,0"
							   VerticalAlignment="Center"
							   Visibility="Collapsed"/>
				</StackPanel>

				<!-- Amplitude bar (visible only while recording) -->
				<Grid x:Name="AmplitudeRow" Height="3" Margin="0" Visibility="Collapsed">
					<Rectangle Fill="#22FFFFFF" RadiusX="1" RadiusY="1"/>
					<Rectangle x:Name="AmplitudeBar"
								   Fill="{StaticResource AccentRecordingBrush}"
								   RadiusX="1" RadiusY="1"
								   HorizontalAlignment="Left"
								   Width="0"/>
				</Grid>
				
			</StackPanel>

		</StackPanel>
	</Border>
</Window>
